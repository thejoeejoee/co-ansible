          "instant": true,
          "legendFormat": "",
          "refId": "Egress"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (name) (increase(paths_inbound_frames_in_error{name!~\"x/.*\"}[5m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Errors"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "name" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "renameByName": {
              "name": "Slot",
              "Value #Readers": "Readers",
              "Value #Ingest": "Ingest Mbps",
              "Value #Egress": "Egress Mbps",
              "Value #Errors": "Errors (5m)"
            },
            "indexByName": {
              "name": 0,
              "Value #Readers": 1,
              "Value #Ingest": 2,
              "Value #Egress": 3,
              "Value #Errors": 4
            }
          }
        }
      ]
    },

