      "title": "Slot Status",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (name) (paths_readers{name!~\"x/.*\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Readers"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (name) (rate(paths_inbound_bytes{name!~\"x/.*\"}[1m])) * 8 / 1e6",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Ingest"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (name) (rate(paths_outbound_bytes{name!~\"x/.*\"}[1m])) * 8 / 1e6",
